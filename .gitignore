# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
dist/
.playwright-mcp/

# Tooling caches
.pytest_cache/
.ruff_cache/

# Editor and OS noise
.DS_Store

# Local secrets
.env
.env.local

# Claude Code per-checkout state
.claude/

# Word/PDF artifacts at repo root (generated by whetstone/scribe CLIs)
/*.docx
/*.pdf

# Smoke-run / scratch review outputs at repo root — keep them under
# docs/results/smoke/ if they're worth keeping, otherwise discard.
/smoke_*.md
/reviewed*.docx

# Git worktrees (kept inside the repo so Claude Code's permission scope covers them)
.worktrees/

# scribe & figures local artifacts
benchmarks/*/output/

benchmarks/*/results/
