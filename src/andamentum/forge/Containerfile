# The forge sandbox image — the strong (host-isolation) execution tier (the default).
#
# Build (from the repo root):
#   podman build -t andamentum-forge-sandbox -f src/andamentum/forge/Containerfile .
#
# forge's audit (stage 4) runs each built system's test suite + end-to-end smoke inside
# an ephemeral container from this image, with `--network none` (pure systems) and
# memory/pids caps. The generated package is COPIED IN over stdin (a tar stream unpacked
# under /home/sandbox/pkg) — not bind-mounted — so no host path is shared into the VM and
# a generated body can touch nothing on the host. This image only provides the lean
# andamentum runtime.
#
# Lean by design: a generated package imports `andamentum.forge.runtime`, which runs
# `andamentum/forge/__init__.py` — today an eager re-export that pulls the builder chain
# (audit → agents → pydantic-ai; diagnose / schemas → rapidfuzz) plus the runtime (→ core).
# So the import surface is pydantic / pydantic-graph / pydantic-ai / rapidfuzz / numpy /
# httpx / rich — but never torch / docling / matplotlib. We install that subset explicitly
# (WITH deps, so pydantic-ai's own requirements resolve) + pytest, then `andamentum
# --no-deps` (source only). Small image, fast build, faithful host-isolated sandbox.
# (A future __init__-laziness cleanup could drop the builder deps here — see TIER2 plan.)
#
# This is the default backend (PodmanSandbox). If podman is not installed, a *pure* run
# degrades to an out-of-process subprocess with a warning; a *network* run refuses. To opt
# out of containers entirely, pass `--sandbox subprocess` (no host isolation).

FROM python:3.13-slim

# Run as a non-root user inside the container (defence in depth).
RUN useradd --create-home --uid 10001 sandbox
WORKDIR /opt/andamentum

COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir pydantic "pydantic-graph>=0.1,<2" pydantic-ai rapidfuzz numpy httpx rich pytest \
    && pip install --no-cache-dir --no-deps .

USER sandbox
# No ENTRYPOINT: forge invokes `python -m pytest <pkg>/tests` inside this image.
